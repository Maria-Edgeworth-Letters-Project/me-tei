                     <idno type="SNAC">36015579</idno>
                  </persName>
                  to <persName ref="./Personography.xml#DumoE1"> Etienne Dumont</persName>, <placeName><!--Location where letter was sent--></placeName>, 
                  <date when="1811-02-24">Feb<hi rend="superscript">y</hi>. 24<hi rend="superscript">th</hi>. 1811</date>
                  <!-- <stamp>Enter description, if applicable</stamp>-->
               </head>
